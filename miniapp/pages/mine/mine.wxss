.container { padding: 32rpx; }
.section-title { font-size: 30rpx; font-weight: 700; color: #333; margin-bottom: 20rpx; }

.quota-card, .redeem-card {
  background: #fff; border-radius: 20rpx; padding: 28rpx;
  margin-bottom: 24rpx; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}
.quota-row { display: flex; }
.quota-item { flex: 1; text-align: center; }
.quota-num { font-size: 48rpx; font-weight: 800; color: #e94560; }
.quota-label { font-size: 24rpx; color: #999; display: block; margin-top: 8rpx; }

.sub-status {
  margin-top: 16rpx; text-align: center;
  background: #f0fff0; color: #4caf50;
  padding: 10rpx; border-radius: 10rpx; font-size: 24rpx;
}

.redeem-row { display: flex; gap: 16rpx; }
.code-input {
  flex: 1; height: 80rpx; padding: 0 20rpx;
  background: #f5f5f5; border-radius: 12rpx;
  font-size: 28rpx; text-transform: uppercase;
}
.redeem-btn {
  width: 140rpx; height: 80rpx;
  background: #e94560; color: #fff; font-size: 28rpx;
  border-radius: 12rpx; border: none;
  text-align: center; line-height: 80rpx;
}
.redeem-btn[disabled] { opacity: 0.6; }

.redeem-msg { margin-top: 16rpx; font-size: 26rpx; padding: 12rpx; border-radius: 10rpx; }
.redeem-msg.success { background: #f0fff0; color: #4caf50; }
.redeem-msg.fail { background: #fff3f3; color: #e94560; }

.price-info { display: flex; justify-content: space-between; margin-top: 16rpx; font-size: 22rpx; color: #ccc; }
.buy-hint { color: #e94560; }

.task-item {
  display: flex; align-items: center; gap: 16rpx;
  background: #fff; padding: 20rpx 24rpx; margin-bottom: 12rpx;
  border-radius: 16rpx;
}
.task-status { width: 12rpx; height: 12rpx; border-radius: 6rpx; }
.task-status.completed { background: #4caf50; }
.task-status.failed { background: #e94560; }
.task-status.pending { background: #ff9800; }
.task-status.downloading { background: #2196f3; }
.task-status.transcribing { background: #2196f3; }
.task-status.summarizing { background: #9c27b0; }
.task-info { flex: 1; display: flex; flex-direction: column; }
.task-url { font-size: 26rpx; color: #333; max-width: 500rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.task-time { font-size: 22rpx; color: #ccc; margin-top: 6rpx; }
.empty { text-align: center; color: #ccc; padding: 60rpx 0; }
